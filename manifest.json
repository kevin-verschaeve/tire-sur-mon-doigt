{
    "manifest_version": 2,
    "name": "Tire sur mon doigt !",
    "description": "Tu tires sur mon doigt et je lâche une caisse !",
    "version": "1.0",
    "browser_action": {
      "default_icon": "meta/favicon-32x32.png",
      "default_popup": "index.html"
    },
    "icons": {
      "16": "meta/favicon-16x16.png",
      "32": "meta/favicon-32x32.png",
      "48": "meta/android-chrome-192x192.png",
      "128": "meta/android-chrome-192x192.png"
    },
    "content_security_policy": "script-src 'self' https://*.gstatic.com https://*.jsdelivr.net; object-src 'self'"
}
  